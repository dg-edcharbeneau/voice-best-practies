{
  "name": "voice-ui-best-practices-react",
  "version": "1.0.0",
  "description": "React implementation of the realtime voice UI best practices, built on Deepgram streaming STT (Flux) and TTS.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/server.mjs",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "node server/server.mjs",
    "start": "npm run build && node server/server.mjs"
  },
  "keywords": [
    "deepgram",
    "voice",
    "react",
    "speech-to-text",
    "text-to-speech",
    "flux",
    "realtime",
    "voice-ui",
    "barge-in"
  ],
  "license": "MIT",
  "dependencies": {
    "@deepgram/sdk": "^5.5.0",
    "dotenv": "^16.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^6.0.0"
  }
}
