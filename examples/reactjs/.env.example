# Copy this file to `.env` and fill in your Deepgram API key.
# Get one at https://console.deepgram.com
#
# This key lives ONLY on the server. It is used to mint short-lived
# tokens for the browser and is never sent to the client.
DEEPGRAM_API_KEY=

# Port the Node token server listens on. In dev, Vite (5173) proxies
# /api/token here. In prod, this server also serves the built app.
PORT=3000

# Time-to-live (seconds) for the browser tokens minted by /api/token.
# The JWT TTL only needs to cover the WebSocket handshake; once a socket
# is open, token expiry does not close it. Keep this short.
TOKEN_TTL_SECONDS=60
